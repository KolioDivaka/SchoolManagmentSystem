@model SchoolManagmentSystem.ViewModels.GradesFormViewModel

@{
    ViewData["Title"] = "Edit Grade";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4>Edit Grade</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label">Student</label>
                            <select asp-for="StudentId" class="form-select"
                                    asp-items="Model.Students">
                                <option value="">-- Select Student --</option>
                            </select>
                            <span asp-validation-for="StudentId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SubjectId" class="form-label">Subject</label>
                            <select asp-for="SubjectId" class="form-select"
                                    asp-items="Model.Subjects">
                                <option value="">-- Select Subject --</option>
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Mark" class="form-label"></label>
                            <input asp-for="Mark" class="form-control" />
                            <span asp-validation-for="Mark" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Term" class="form-label"></label>
                            <input asp-for="Term" class="form-control" />
                            <span asp-validation-for="Term" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Update</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}