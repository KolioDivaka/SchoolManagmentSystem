@model IEnumerable<SchoolManagmentSystem.Models.Subject>

@{
    ViewData["Title"] = "Subjects";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Subjects</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add Subject</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No subjects found.</div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subject in Model)
                {
                    <tr>
                        <td>@subject.Id</td>
                        <td>@subject.Name</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@subject.Id"
                               class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@subject.Id"
                               class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>