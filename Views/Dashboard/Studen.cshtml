@model SchoolManagmentSystem.Models.Student

@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Welcome, @Model.FullName 👋</h2>

    <!-- Profile Card -->
    <div class="row mb-4">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">My Profile</h5>
                </div>
                <div class="card-body">
                    <table class="table mb-0">
                        <tr>
                            <th>Full Name</th>
                            <td>@Model.FullName</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>
                        <tr>
                            <th>Date of Birth</th>
                            <td>@Model.DateOfBirth.ToString("dd/MM/yyyy")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- My Grades -->
    <h4 class="mb-3">My Grades</h4>

    @if (Model.Grades == null || !Model.Grades.Any())
    {
        <div class="alert alert-info">No grades available yet.</div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Subject</th>
                    <th>Mark</th>
                    <th>Term</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var grade in Model.Grades)
                {
                    <tr>
                        <td>@grade.Subject?.Name</td>
                        <td>
                            <span class="badge @(grade.Mark >= 4 ? "bg-success" : "bg-danger")">
                                @grade.Mark
                            </span>
                        </td>
                        <td>@grade.Term</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Average -->
        <div class="mt-3">
            <strong>Average Mark: </strong>
            <span class="badge bg-primary fs-6">
                @Model.Grades.Average(g => g.Mark).ToString("F2")
            </span>
        </div>
    }
</div>