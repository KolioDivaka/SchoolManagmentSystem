@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>

    <!-- Summary Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total Students</h6>
                        <h2 class="mb-0">@ViewBag.StudentCount</h2>
                    </div>
                    <span style="font-size: 3rem;">🎓</span>
                </div>
                <div class="card-footer">
                    <a asp-controller="Students" asp-action="Index"
                       class="text-white text-decoration-none small">View all students →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total Subjects</h6>
                        <h2 class="mb-0">@ViewBag.SubjectCount</h2>
                    </div>
                    <span style="font-size: 3rem;">📚</span>
                </div>
                <div class="card-footer">
                    <a asp-controller="Subjects" asp-action="Index"
                       class="text-white text-decoration-none small">View all subjects →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-warning shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total Grades</h6>
                        <h2 class="mb-0">@ViewBag.GradeCount</h2>
                    </div>
                    <span style="font-size: 3rem;">📝</span>
                </div>
                <div class="card-footer">
                    <a asp-controller="Grades" asp-action="Index"
                       class="text-white text-decoration-none small">View all grades →</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <h4 class="mb-3">Quick Actions</h4>
    <div class="row g-3">
        <div class="col-md-4">
            <a asp-controller="Students" asp-action="Create"
               class="btn btn-outline-primary w-100 py-3">
                + Add New Student
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Subjects" asp-action="Create"
               class="btn btn-outline-success w-100 py-3">
                + Add New Subject
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Grades" asp-action="Create"
               class="btn btn-outline-warning w-100 py-3">
                + Add New Grade
            </a>
        </div>
    </div>
</div>